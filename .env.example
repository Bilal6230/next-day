# Copy this file to .env and fill in values from Firebase Console → Project settings → Your apps.
#
# EXPO_PUBLIC_* variables are bundled into the app at build time (standard for Firebase mobile/web SDKs).
# Do not commit .env — it is gitignored.
#
# After updating .env, restart Expo.
#
# For abuse protection before production, add Firebase App Check, API key restrictions (Google Cloud Console),
# and ensure firestore.rules from this repo are deployed.

EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
