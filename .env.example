# Copy to .env and fill with values from Firebase Console → Project settings → Your apps.
# EXPO_PUBLIC_* vars are bundled into the client (standard for Firebase web/mobile SDK).
# Restrict abuse via Firebase App Check, API key restrictions, and Firestore security rules.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
